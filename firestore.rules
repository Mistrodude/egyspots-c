rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Spots: anyone can read; checkins counter can be updated by any auth user;
    // full writes (admin only via custom claims or service account)
    match /spots/{spotId} {
      allow read: if true;
      allow update: if request.auth != null
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['checkins']);
      allow write: if request.auth != null && request.auth.token.admin == true;
    }

    // Users: each user can only read and write their own document
    match /users/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }

    // Messages: anyone can read; authenticated users can create their own messages
    match /messages/{messageId} {
      allow read: if true;
      allow create: if request.auth != null
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.text is string
        && request.resource.data.text.size() > 0
        && request.resource.data.text.size() <= 500;
      allow delete: if request.auth != null && resource.data.userId == request.auth.uid;
    }

    // Reviews: anyone can read; authenticated users can create one review per spot
    match /reviews/{reviewId} {
      allow read: if true;
      allow create: if request.auth != null
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.rating is int
        && request.resource.data.rating >= 1
        && request.resource.data.rating <= 5
        && request.resource.data.text is string
        && request.resource.data.text.size() <= 1000;
      allow delete: if request.auth != null && resource.data.userId == request.auth.uid;
    }
  }
}
