rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() { return request.auth != null; }
    function isAdmin() { return isSignedIn() && request.auth.token.admin == true; }
    function isOwner(uid) { return isSignedIn() && request.auth.uid == uid; }
    function onlyKeys(keys) {
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly(keys);
    }

    match /spots/{spotId} {
      allow read: if true;

      allow create: if isSignedIn()
        && (request.resource.data.founderId == request.auth.uid
            || request.resource.data.founderId == 'seed_founder');

      // Founder: full update of their spot.
      // Any auth user: update check-in counters or rating fields only.
      allow update: if isAdmin()
        || (isSignedIn() && resource.data.founderId == request.auth.uid)
        || (isSignedIn() && onlyKeys(['checkins', 'totalCheckins', 'checkinsToday', 'weeklyCheckins', 'crowd', 'crowdPct']))
        || (isSignedIn() && onlyKeys(['ratingSum', 'ratingCount', 'rating']));

      // Founder or admin can delete.
      allow delete: if isAdmin()
        || (isSignedIn() && resource.data.founderId == request.auth.uid);

      // Ratings subcollection: any user can read; only owner can write their own rating.
      match /ratings/{userId} {
        allow read: if true;
        allow create, update: if isSignedIn()
          && request.auth.uid == userId
          && request.resource.data.rating is number
          && request.resource.data.rating >= 1
          && request.resource.data.rating <= 5;
        allow delete: if isSignedIn() && request.auth.uid == userId;
      }

      // Messages subcollection: public read; auth users create own; owner delete.
      match /messages/{messageId} {
        allow read: if true;
        allow create: if isSignedIn()
          && request.resource.data.userId == request.auth.uid
          && request.resource.data.text is string
          && request.resource.data.text.size() > 0
          && request.resource.data.text.size() <= 500;
        allow delete: if isSignedIn() && resource.data.userId == request.auth.uid;
      }
    }

    // Users: owner or admin only.
    match /users/{uid} {
      allow read, write: if isOwner(uid) || isAdmin();
    }

    // Check-ins: public read; auth users create own; owner delete.
    match /checkins/{checkinId} {
      allow read: if true;
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow delete: if isSignedIn() && resource.data.userId == request.auth.uid;
    }

    // Stories: public read; auth users create own (TTL enforced by Firestore policy);
    //          any auth user can update viewCount/viewedBy; owner or admin delete.
    match /stories/{storyId} {
      allow read: if true;
      allow create: if isSignedIn()
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.expiresAt is timestamp
        && request.resource.data.caption.size() <= 150;
      allow update: if isSignedIn()
        && request.resource.data.diff(resource.data).affectedKeys()
           .hasOnly(['viewCount', 'viewedBy']);
      allow delete: if isSignedIn()
        && (resource.data.userId == request.auth.uid || isAdmin());
    }

    // Notifications: receiver can read/update; any auth user can create (check-in + story events);
    //                receiver or admin can delete.
    match /notifications/{notifId} {
      allow read, update: if isSignedIn() && resource.data.toUserId == request.auth.uid;
      allow create: if isSignedIn();
      allow delete: if isAdmin()
        || (isSignedIn() && resource.data.toUserId == request.auth.uid);
    }

    // Reports: auth users create own; admin read/update/delete.
    match /reports/{reportId} {
      allow create: if isSignedIn() && request.resource.data.reportedBy == request.auth.uid;
      allow read, update, delete: if isAdmin();
    }
  }
}
